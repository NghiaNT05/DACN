{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/incident-report.schema.json",
  "title": "AIOps Incident Report (Graph RAG RCA)",
  "type": "object",
  "required": [
    "report_version",
    "generated_at",
    "incident_question",
    "rca_source",
    "rca_result",
    "audit",
    "artifacts"
  ],
  "properties": {
    "report_version": { "type": "string", "enum": ["2.0"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "incident_question": { "type": "string" },
    "rca_source": { "type": "string", "enum": ["graph-rag-llm"] },
    "rca_result": {
      "type": "object",
      "required": [
        "status",
        "root_cause",
        "confidence",
        "candidate_roots",
        "reasoning",
        "impacted_services",
        "evidence",
        "anomalies",
        "suggested_actions"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "insufficient_data", "degraded_datasource"]
        },
        "root_cause": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "candidate_roots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["service", "rank", "evidence_strength", "evidence"],
            "properties": {
              "service": { "type": "string" },
              "rank": { "type": "integer", "minimum": 1 },
              "evidence_strength": { "type": "string", "enum": ["high", "medium", "low"] },
              "evidence": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "reasoning": { "type": "string" },
        "impacted_services": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "anomalies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["service", "type", "value", "threshold", "source"],
            "properties": {
              "service": { "type": "string" },
              "type": { "type": "string" },
              "value": { "type": ["number", "integer"] },
              "threshold": { "type": ["number", "integer"] },
              "source": { "type": "string" }
            }
          }
        },
        "suggested_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "llm_raw_output": { "type": "string" },
    "audit": {
      "type": "object",
      "required": ["run_id", "model", "embedding_model", "prompt_version", "context_counts"],
      "properties": {
        "run_id": { "type": "string" },
        "model": { "type": "string" },
        "embedding_model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "graph_summary": {
          "type": "object",
          "properties": {
            "node_count": { "type": ["integer", "number"] },
            "seed_services": { "type": "array", "items": { "type": "string" } },
            "candidate_roots": { "type": "array" },
            "causal_paths": { "type": "array" }
          },
          "additionalProperties": true
        },
        "rag_quality": {
          "type": "object",
          "properties": {
            "hit_count": { "type": ["integer", "number"] },
            "has_hits": { "type": "boolean" },
            "has_signal_diversity": { "type": "boolean" },
            "has_source_type_diversity": { "type": "boolean" },
            "covered_service_count": { "type": ["integer", "number"] }
          },
          "additionalProperties": true
        },
        "retrieval_summary": {
          "type": "object",
          "properties": {
            "query": { "type": "string" },
            "top_k": { "type": ["integer", "number"] },
            "hit_count": { "type": ["integer", "number"] },
            "sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "hits": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "rank": { "type": ["integer", "number"] },
                  "score": { "type": "number" },
                  "source": { "type": "string" },
                  "source_type": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "context_counts": {
          "type": "object",
          "properties": {
            "total_rows": { "type": ["integer", "number"] },
            "metrics": { "type": ["integer", "number"] },
            "logs": { "type": ["integer", "number"] },
            "telemetry_errors": { "type": ["integer", "number"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "datasource_health": { "type": "object" },
    "artifacts": {
      "type": "object",
      "required": ["snapshot_path", "cmdb_path"],
      "properties": {
        "snapshot_path": { "type": "string" },
        "cmdb_path": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
